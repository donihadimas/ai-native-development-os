{
  "name": "@donihadimas/aios",
  "version": "0.5.0",
  "description": "Small CLI for AI-Native Development OS.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://donihadimas.github.io/ai-native-development-os/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donihadimas/ai-native-development-os.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/donihadimas/ai-native-development-os/issues"
  },
  "author": {
    "name": "Doni Hadimas",
    "url": "https://github.com/donihadimas"
  },
  "keywords": [
    "ai",
    "codex",
    "developer-tools",
    "cli",
    "boilerplate",
    "workflow",
    "openapi"
  ],
  "bin": {
    "aios": "dist/src/index.js"
  },
  "files": [
    "README.md",
    "LICENSE",
    "NOTICE.md",
    "dist/src/**",
    "assets/**"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "sync-assets": "node scripts/sync-assets.mjs",
    "test": "npm run build && node --test dist/test/*.test.js",
    "aios": "npm run build --silent && node dist/src/index.js",
    "pack:dry": "npm pack --dry-run",
    "prepack": "npm run sync-assets && npm run build",
    "prepublishOnly": "npm test"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2"
  }
}
