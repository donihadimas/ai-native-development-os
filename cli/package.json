{
  "name": "@donihadimas/aios",
  "version": "0.2.0",
  "description": "Small CLI for AI-Native Development OS V2.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "ai",
    "codex",
    "developer-tools",
    "cli",
    "boilerplate",
    "workflow",
    "openapi"
  ],
  "bin": {
    "aios": "dist/src/index.js"
  },
  "files": [
    "README.md",
    "LICENSE",
    "dist/src/**",
    "assets/**"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "sync-assets": "node scripts/sync-assets.mjs",
    "test": "npm run build && node --test dist/test/*.test.js",
    "aios": "npm run build --silent && node dist/src/index.js",
    "pack:dry": "npm pack --dry-run",
    "prepack": "npm run sync-assets && npm run build",
    "prepublishOnly": "npm test"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
