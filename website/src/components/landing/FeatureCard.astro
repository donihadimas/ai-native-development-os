---
interface Props {
  title: string;
  description: string;
  path?: string;
  icon?: string;
  href?: string;
  span?: number;
}

const { title, description, path, icon, href, span = 1 } = Astro.props;

const Tag = href ? 'a' : 'div';
const hrefProp = href ? { href } : {};
---

<Tag class={`feature-card card span-${span}`} {...hrefProp}>
  {path && <div class="card-path"><code>{path}</code></div>}
  <h3 class="card-title">{title}</h3>
  <p class="card-description">{description}</p>
  <slot />
</Tag>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: linear-gradient(180deg, var(--color-card-start), var(--color-card-end));
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem;
    transition: border-color 0.15s ease;
    min-width: 0;
    text-decoration: none;
  }
  a.card:hover {
    border-color: var(--color-border-strong);
  }
  .span-2 {
    grid-column: span 2;
  }
  .card-path {
    margin-bottom: 0.75rem;
  }
  .card-path code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    padding: 0.2rem 0.5rem;
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    color: var(--color-accent);
    overflow-wrap: anywhere;
  }
  .card-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.5rem;
    margin-top: 0;
  }
  .card-description {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0;
  }
  @media (max-width: 768px) {
    .span-2 {
      grid-column: span 1;
    }
  }
</style>
